__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# A player's in-progress journey, not source. `*.bak`/`*.checkpoint.json` cover
# save backups pulled down from the server for recovery, so a stray one can't be
# committed to a public repo.
savegame.json
saves/
*.bak
*.checkpoint.json
*.transcript.json

# Credentials. This repository is public: a key committed here is a key
# published, and rotating it afterwards is the only remedy. These patterns are
# deliberately wide -- it costs nothing to ignore a file that was never
# secret, and everything to track one that was.
.env
.env.*
.secrets/
secrets/
*.key
*.pem
*secret*.json
*credentials*.json
